generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  telegramId   BigInt   @unique
  username     String?
  firstName    String
  lastName     String?
  photoUrl     String?
  language     String   @default("en")
  balance      Float    @default(0)
  hideBalance  Boolean  @default(false)
  pushNotify   Boolean  @default(true)
  isAdmin      Boolean  @default(false)
  referralCode String   @unique @default(cuid())
  referredBy   String?
  referredUser User?    @relation("Referrals", fields: [referredBy], references: [id])
  referrals    User[]   @relation("Referrals")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       Order[]
  transactions Transaction[]
  paymentReqs  PaymentRequest[]
}

enum ProductCategory {
  API
  ACCOUNT
  LICENSE
  EDUCATION
  OTHER
}

model Product {
  id          String          @id @default(cuid())
  title       String
  description String
  category    ProductCategory @default(OTHER)
  tag         String?
  price       Float
  priceSuffix String?
  features    String[]
  stock       Int             @default(0)
  imageUrl    String?
  isActive    Boolean         @default(true)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  orders      Order[]
  items       ProductItem[]
  packages    ProductPackage[]
}

model ProductPackage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  nameEn    String
  nameFa    String
  price     Float
  createdAt DateTime @default(now())
}

model ProductItem {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  content   String
  isUsed    Boolean  @default(false)
  usedAt    DateTime?
  orderId   String?
  createdAt DateTime @default(now())
}

enum OrderStatus {
  PENDING
  PAID
  DELIVERING
  COMPLETED
  CANCELLED
  REFUNDED
}

model Order {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  productId  String
  product    Product     @relation(fields: [productId], references: [id])
  quantity   Int         @default(1)
  price      Float
  status     OrderStatus @default(PENDING)
  deliveryContent String?
  notes      String?
  packageId  String?
  packageName String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  transaction Transaction?
}

enum TransactionType {
  DEPOSIT
  PURCHASE
  REFUND
  BONUS
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Transaction {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id])
  orderId   String?           @unique
  order     Order?            @relation(fields: [orderId], references: [id])
  type      TransactionType
  status    TransactionStatus @default(PENDING)
  amount    Float
  note      String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

enum PaymentMethod {
  CARD
  CRYPTO_USDT
  CRYPTO_TON
  BALANCE
}

enum PaymentRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model PaymentRequest {
  id           String               @id @default(cuid())
  userId       String
  user         User                 @relation(fields: [userId], references: [id])
  method       PaymentMethod
  amount       Float
  status       PaymentRequestStatus @default(PENDING)
  screenshotUrl String?
  txHash       String?
  notes        String?
  adminNote    String?
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}
